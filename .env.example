# Wiki Vault (local path — clone from https://github.com/gnust-company/innovation_hub_wiki)
WIKI_PATH=/path/to/innovation_hub_wiki

# Environment (development | production — disables docs, enables JSON logging in production)
AGENT_ENV=development

# NVIDIA NIM (OpenAI-compatible endpoint)
NVIDIA_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxx
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
MODEL_NAME=moonshotai/kimi-k2.5

# Agent Config
MAX_TOOL_CALLS=10
MAX_DEPTH=3

# LangFuse (optional — monitoring)
LANGFUSE_PUBLIC_KEY=pk-...
LANGFUSE_SECRET_KEY=sk-...
LANGFUSE_HOST=https://cloud.langfuse.com

# API Key — shared secret with Hub BE (required)
AGENT_API_KEY=sk-agent-xxxxxxxxxxxxxxxxxxxx

# IP Allowlist — optional, comma-separated (leave empty to allow all)
AGENT_ALLOWED_IPS=

# CORS Origins — optional, comma-separated (leave empty to disable CORS)
# Only needed if Agent BE receives direct browser requests
AGENT_CORS_ORIGINS=
