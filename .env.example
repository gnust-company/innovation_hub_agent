# Wiki Vault (local path — clone from https://github.com/gnust-company/innovation_hub_wiki)
WIKI_PATH=/path/to/innovation_hub_wiki

# LLM Provider
MODEL_PROVIDER=openai          # openai | deepseek | custom
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx
OPENAI_BASE_URL=               # Optional: custom endpoint (e.g. DeepSeek)
MODEL_NAME=gpt-4o-mini         # Model to use

# Agent Config
MAX_TOOL_CALLS=10
MAX_DEPTH=3
